{
  "crons": [
    {
      "path": "/api/cron/monthly-snapshot",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/process-autopay",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/agents/cmo/daily_audit",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/agents/cmo/daily_forum_scan",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/agents/cmo/weekly_content",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/agents/cmo/weekly_budget_review",
      "schedule": "0 15 * * 1"
    },
    {
      "path": "/api/cron/agents/cmo/weekly_outreach",
      "schedule": "0 16 * * 2"
    },
    {
      "path": "/api/cron/agents/cmo/weekly_linkable_asset_audit",
      "schedule": "0 13 * * 3"
    },
    {
      "path": "/api/cron/agents/cmo/weekly_content_refresh",
      "schedule": "0 13 * * 4"
    },
    {
      "path": "/api/cron/agents/cmo/monthly_pseo",
      "schedule": "0 14 1 * *"
    },
    {
      "path": "/api/cron/agents/cmo/monthly_tool_proposal",
      "schedule": "0 14 2 * *"
    },
    {
      "path": "/api/cron/agents/cpo/daily_flow_audit",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/agents/cpo/weekly_friction_synthesis",
      "schedule": "0 16 * * 1"
    },
    {
      "path": "/api/cron/agents/cpo/weekly_ai_human_balance_review",
      "schedule": "0 16 * * 2"
    },
    {
      "path": "/api/cron/agents/cpo/monthly_competitive_ux_audit",
      "schedule": "0 16 1 * *"
    },
    {
      "path": "/api/cron/agents/notifications/daily_digest",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/agents/dev/process_build_queue",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/compliance/annual-cpi-update",
      "schedule": "0 16 2 1 *"
    },
    {
      "path": "/api/cron/compliance/increase-window-check",
      "schedule": "0 15 * * *"
    }
  ],
  "functions": {
    "app/api/extract-lease/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/process-document/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/cron/monthly-snapshot/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/agents/[role]/run/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/cron/agents/[role]/[task]/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/cron/agents/dev/process_build_queue/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/((?!api/|_next/static/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(favicon.ico|robots.txt|sitemap.xml|og-image.png|apple-touch-icon.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
